{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build DEBUG",
            "type": "shell",
            "command": "mingw32-make",
            "args": [
                "debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}/c-code"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/c-code"
                ]
            },
            "detail": "Builds the debug version using the Makefile."
        },
        {
            "label": "Build FAST",
            "type": "shell",
            "command": "mingw32-make",
            "args": [
                "fast"
            ],
            "options": {
                "cwd": "${workspaceFolder}/c-code"
            },
            "group": "build",
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/c-code"
                ]
            },
            "detail": "Builds the optimized (fast) version using the Makefile."
        },
        {
            "label": "Clean Project",
            "type": "shell",
            "command": "mingw32-make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}/c-code"
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "Removes all build artifacts using 'make clean'."
        }
    ]
}