                "-Wall",
                "-g",
                "-fopenmp",
                "${workspaceFolder}/c-code/*.c",
                "-lm",
                "-o",
                "${workspaceFolder}/c-code/antibody_sim_debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Linux: Compiles .c files with debug symbols."
        },
        {
            "type": "shell",
            "label": "Build FAST (Linux)",
            "command": "gcc",
            "args": [
                "-Wall",
                "-O3",
                "-fopenmp",
                "${workspaceFolder}/c-code/*.c",
                "-lm",
                "-o",
                "${workspaceFolder}/c-code/antibody_sim_fast"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Linux: Compiles .c files with maximum speed optimization."
        }
    ]
}