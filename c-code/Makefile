# Compiler and flags
CC = gcc
# Common flags for all builds
COMMON_FLAGS = -Wall -Wextra -fopenmp -MMD -MP
# Flags for debug build (default)
DEBUG_FLAGS = -g
# Flags for fast/release build
FAST_FLAGS = -O3

# Linker flags
LDFLAGS = -lm -fopenmp

# Auto-detect platform and set executable extension and RM command
ifeq ($(OS),Windows_NT)
    EXE_EXT := .exe
    RM := del /Q /F
else
    EXE_EXT :=
    RM := rm -f
endif

# Target executable names
TARGET_DEBUG = antibody_sim_debug$(EXE_EXT)
TARGET_FAST = antibody_sim_fast$(EXE_EXT)

# Source files
SRCS = main.c parsing.c chain-operations.c metropolis.c utils.c random.c correlations.c

# Object files directories
OBJ_DIR_DEBUG = obj/debug
OBJ_DIR_FAST = obj/fast

# Object files (derived from source files)
OBJS_DEBUG = $(patsubst %.c,$(OBJ_DIR_DEBUG)/%.o,$(SRCS))
OBJS_FAST = $(patsubst %.c,$(OBJ_DIR_FAST)/%.o,$(SRCS))

# Dependency files (generated by the compiler with -MMD)
DEPS_DEBUG = $(OBJS_DEBUG:.o=.d)
DEPS_FAST = $(OBJS_FAST:.o=.d)

# The default rule: build the executable
all: debug

# Rule to build the debug version
debug: CFLAGS = $(COMMON_FLAGS) $(DEBUG_FLAGS)
debug: $(TARGET_DEBUG)

# Rule to build the fast version
fast: CFLAGS = $(COMMON_FLAGS) $(FAST_FLAGS)
fast: $(TARGET_FAST)

# Rule to link the debug executable
$(TARGET_DEBUG): $(OBJS_DEBUG)
	@echo "Linking debug executable..."
	$(CC) -o $@ $^ $(LDFLAGS)

# Rule to link the fast executable
$(TARGET_FAST): $(OBJS_FAST)
	@echo "Linking fast executable..."
	$(CC) -o $@ $^ $(LDFLAGS)

# Generic rule to compile source files into debug object files
$(OBJ_DIR_DEBUG)/%.o: %.c
	@$(if $(findstring Windows,$(OS)),if not exist $(subst /,\,$(@D)) mkdir $(subst /,\,$(@D)),mkdir -p $(@D))
	@echo "Compiling $< (debug)..."
	$(CC) $(CFLAGS) -c $< -o $@

# Generic rule to compile source files into fast object files
$(OBJ_DIR_FAST)/%.o: %.c
	@$(if $(findstring Windows,$(OS)),if not exist $(subst /,\,$(@D)) mkdir $(subst /,\,$(@D)),mkdir -p $(@D))
	@echo "Compiling $< (fast)..."
	$(CC) $(CFLAGS) -c $< -o $@

# Rule to clean up build artifacts
clean:
	@echo "Cleaning up build artifacts..."
	-$(RM) $(TARGET_DEBUG) $(TARGET_FAST)
ifeq ($(OS),Windows_NT)
	-if exist obj rmdir /S /Q obj
else
	-rm -rf obj
endif

# Include the generated dependency files
-include $(DEPS_DEBUG)
-include $(DEPS_FAST)

.PHONY: all debug fast clean